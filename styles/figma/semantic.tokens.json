  "effects": {
    "shadow": {
      "btn": {
        "primary": {
          "$type": "boxShadow",
          "$value": {
            "x": "{dim.0}",
            "y": "{dim.4}",
            "blur": "{dim.4}",
            "spread": "{dim.0}",
            "color": "rgba( {color.gray.1}, {opacity.20})",
            "type": "dropShadow"
          }
        },
        "secondary": {
          "$type": "boxShadow",
          "$value": {
            "x": "{dim.0}",
            "y": "{dim.0}",
            "blur": "{dim.8}",
            "spread": "{dim.1}",
            "color": "rgba( {color.green.9}, {opacity.20})",
            "type": "dropShadow"
          }
        }
      },
      "surface": {
        "1": {
          "$type": "boxShadow",
          "$value": {
            "x": "{dim.2}",
            "y": "{dim.0}",
            "blur": "{dim.20}",
            "spread": "{dim.0}",
            "color": "rgba( {color.gray.1}, 25%)",
            "type": "dropShadow"
          }
        },
        "2": {
          "$type": "boxShadow",
          "$value": {
            "x": "{dim.0}",
            "y": "{dim.0}",
            "blur": "{dim.40}",
            "spread": "{dim.0}",
            "color": "rgba( {color.green-alpha.4} )",
