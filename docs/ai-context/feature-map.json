{
  "features": {
    "home": {
      "description": "Landing page with hero section, navigation header, and Antaris branding",
      "files": {
        "page": "app/page.tsx",
        "components": [
          "features/home/components/hero-section.tsx",
          "features/home/components/header.tsx",
          "features/home/components/logo.tsx"
        ],
        "barrel": "features/home/index.ts"
      },
      "exports": [
        "HeroSection",
        "HeroHeader",
        "Logo"
      ]
    },
    "user-management": {
      "description": "Full CRUD for user management with list view, detail view, and modal forms",
      "files": {
        "pages": [
          "app/users/page.tsx",
          "app/users/layout.tsx",
          "app/users/[userId]/"
        ],
        "components": [
          "features/users/components/users-list.tsx",
          "features/users/components/user-card.tsx",
          "features/users/components/user-form.tsx",
          "features/users/components/user-modal.tsx",
          "features/users/components/create-user-button.tsx"
        ],
        "hooks": [
          "features/users/hooks/useUserModal.ts"
        ],
        "types": [
          "features/users/types/user-schema.ts"
        ],
        "barrel": "features/users/index.ts",
        "api": [
          "app/(server)/router/user.ts"
        ]
      },
      "exports": [
        "UsersList",
        "UserCard",
        "UserModal",
        "CreateUserButton",
        "UserForm",
        "useUserModal",
        "userFormSchema",
        "UserType"
      ]
    },
    "authentication": {
      "description": "Keycloak OAuth 2.0 + UMA authentication with httpOnly cookie session management and silent token refresh",
      "files": {
        "api-routes": [
          "app/api/auth/[...route]/route.ts"
        ],
        "lib": [
          "lib/auth/keycloak.ts",
          "lib/auth/session.ts"
        ],
        "store": "store/auth-store.ts",
        "provider": "providers/auth-provider.tsx",
        "hook": "hooks/use-auth.ts",
        "middleware": "middleware.ts",
        "route-guard": "proxy.ts"
      },
      "flow": "Keycloak login → OAuth code → token exchange → UMA ticket → httpOnly cookies → middleware refresh → Zustand hydration"
    },
    "trpc-api": {
      "description": "Type-safe RPC API layer built on tRPC v11 with server/client isomorphic access",
      "files": {
        "server": [
          "app/(server)/router/index.ts",
          "app/(server)/router/user.ts",
          "app/(server)/middlewares/base.ts",
          "app/(server)/middlewares/arcjet/standard.ts",
          "app/(server)/middlewares/arcjet/ratelimit.ts",
          "app/(server)/rpc/[[...rest]]/route.ts"
        ],
        "client": [
          "lib/trpc.ts",
          "lib/trpc.server.ts"
        ],
        "query": [
          "lib/query/client.ts",
          "lib/query/hydration.tsx"
        ]
      },
      "namespaces": {
        "user": [
          "list",
          "details",
          "create",
          "update",
          "delete"
        ],
        "mission": [],
        "_mission_note": "Placeholder — satellite mission operations. Empty until ATMOS mission API is integrated."
      },
      "doc": "docs/modules/trpc-api.md"
    },
    "websocket": {
      "description": "WebSocket client with auto-reconnect, auth token injection, and typed message handling",
      "files": {
        "lib": "lib/websocket.ts",
        "hook": "hooks/use-websocket.ts"
      },
      "env": "NEXT_PUBLIC_WEBSOCKET_BACKEND_BASE_URL",
      "doc": "docs/modules/websocket.md"
    },
    "component-docs": {
      "description": "Interactive component documentation portal with live previews, props tables, and code examples",
      "files": {
        "pages": [
          "app/component-docs/page.tsx",
          "app/component-docs/layout.tsx",
          "app/component-docs/[slug]/page.tsx"
        ],
        "config": "app/component-docs/config/components.ts",
        "internal-components": [
          "app/component-docs/_components/DocsSidebar.tsx",
          "app/component-docs/_components/DocsTabs.tsx",
          "app/component-docs/_components/ComponentPreview.tsx",
          "app/component-docs/_components/CodeBlock.tsx",
          "app/component-docs/_components/PropsTable.tsx"
        ]
      },
      "note": "Separate from /preview/* pages — this is the structured docs portal. /preview/* are raw showcase pages."
    },
    "security": {
      "description": "Arcjet-based application security: WAF, bot detection, rate limiting",
      "files": {
        "config": "lib/arcjet.ts",
        "middlewares": [
          "app/(server)/middlewares/arcjet/standard.ts",
          "app/(server)/middlewares/arcjet/ratelimit.ts"
        ]
      },
      "rules": {
        "standard": [
          "shield (WAF)",
          "detectBot"
        ],
        "ratelimit": [
          "slidingWindow (1 req/min)"
        ]
      }
    },
    "catalog": {
      "description": "Satellite component catalog — browse and select hardware for a mission. Features a high-performance dual-registry architecture with context-locked selection.",
      "files": {
        "pages": [
          "app/(antaris)/catalog/page.tsx",
          "app/(antaris)/catalog/layout.tsx"
        ],
        "components": [
          "features/catalog/components/sidepanel/catalog-card.tsx",
          "features/catalog/components/sidepanel/catalog-list.tsx",
          "features/catalog/components/sidepanel/catalog-sidepanel.tsx",
          "features/catalog/components/sidepanel/catalog-category-drawer.tsx",
          "features/catalog/components/preview/catalog-component-preview.tsx",
          "features/catalog/components/catalog-stats.tsx"
        ],
        "hooks": [
          "features/catalog/hooks/use-catalog-navigation.ts",
          "features/catalog/hooks/use-catalog-selection.ts",
          "features/catalog/hooks/use-catalog-groups.ts",
          "features/catalog/hooks/use-catalog-stats.ts"
        ],
        "types": [
          "features/catalog/types/catalog-data-types.ts",
          "features/catalog/types/catalog-selection-state-types.tsx"
        ],
        "mock": "features/catalog/utils/mock-data.ts",
        "barrel": "features/catalog/index.ts"
      },
      "exports": [
        "useCatalogSelection",
        "useCatalogNavigation",
        "useCatalogGroups",
        "useCatalogStats",
        "CatalogSidepanel"
      ],
      "interfaces": [
        "CatalogCategoryTypes",
        "CatalogSubsystemTypes",
        "CatalogItem",
        "CatalogGroup",
        "CatalogStatRowData"
      ],
      "doc": "docs/features/catalog.md"
    },
    "design-system": {
      "description": "Figma-synced design tokens and 37 UI components",
      "files": {
        "tokens": [
          "styles/src/index.css",
          "styles/src/antaris-theme.css",
          "styles/src/tokens.generated.ts",
          "styles/src/fonts.generated.tsx",
          "styles/sd.config.mjs"
        ],
        "figma-source": "styles/figma/",
        "globals": "app/globals.css",
        "components": "components/ui/",
        "config": [
          "components.json",
          "tailwind.config.ts"
        ]
      },
      "component-list": [
        "accordion", "alert-dialog", "avatar", "badge",
        "button", "card", "checkbox", "collapsible", "drawer", "dialog",
        "dropdown-menu", "icon-button",
        "input-group", "input", "kbd", "radio-group", "resizable",
        "scroll-area", "select", "separator", "sheet", "input-range",
        "sidebar", "skeleton", "sonner", "spinner", "table", "tabs",
        "text", "textarea", "toaster", "tooltip"
      ],
      "_count": "43 components total"
    },
    "component-previews": {
      "description": "Interactive preview pages for each design system component",
      "files": {
        "pages": [
          "app/preview/button/", "app/preview/card/", "app/preview/checkbox/",
          "app/preview/drawer/", "app/preview/custom-text/", "app/preview/input/",
          "app/preview/radio/", "app/preview/separator-test/", "app/preview/side-nav/",
          "app/preview/sidebar-test/", "app/preview/tabs/", "app/preview/icon-button/",
          "app/preview/input-range/", "app/preview/sheet/",
          "app/preview/accordion/"
        ]
      }
    },
    "theming": {
      "description": "Dark/light theme switching with next-themes",
      "files": {
        "provider": "providers/theme-provider.tsx",
        "tokens": "styles/src/index.css"
      },
      "default": "dark"
    },
    "providers": {
      "description": "Global provider tree: Theme → Auth → TanStack Query → Modals",
      "files": {
        "composition": "providers/index.tsx",
        "providers": [
          "providers/theme-provider.tsx",
          "providers/auth-provider.tsx",
          "providers/tanstack-query-provider.tsx",
          "providers/modals-provider.tsx",
          "providers/background-provider.tsx"
        ]
      },
      "order": [
        "ThemeProvider",
        "AuthProvider",
        "TanstackQueryProvider",
        "ModalsProvider"
      ]
    },
    "icons": {
      "description": "Custom SVG icon system with build pipeline. Lucide for generic UI icons.",
      "files": {
        "source": "icons/svg/",
        "generated": "icons/src/",
        "build": "icons/build.js",
        "barrel": "icons/index.ts"
      },
      "third-party": {
        "lucide-react": "General UI icons (primary third-party library)",
        "@tabler/icons-react": "Available, minimal usage"
      }
    },
    "splash-screen": {
      "description": "Orchestrated SVG animation intro with orbital entry/exit, satellite scattering, and brand assembly",
      "files": {
        "components": [
          "features/splash-screen/components/splash-screen.tsx"
        ],
        "constants": "features/splash-screen/constants.ts",
        "barrel": "features/splash-screen/index.ts",
        "integration": "app/layout.tsx"
      },
      "animation-sequence": [
        "Enter: orbital arc entry",
        "Morph-In: satellite scatters to reveal logo",
        "Hold: brand display",
        "Morph-Out: logo scatters back to satellite",
        "Exit: orbital accelerated departure"
      ]
    }
  }
}
